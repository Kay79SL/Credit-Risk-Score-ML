    "# -----------------------------------------------------------------------------\n",
    "# HELPERS\n",
    "# -----------------------------------------------------------------------------\n",
    "def print_df(df: pd.DataFrame, name: str, n: int = 10):\n",
    "    print(\"\\n\" + \"-\" * 95)\n",
    "    print(f\"[DATAFRAME] {name} | shape = {df.shape[0]:,} rows × {df.shape[1]:,} cols\")\n",
    "    print(\"-\" * 95)\n",
    "    print(df.head(n).to_string())\n",
    "\n",
    "def section(title: str):\n",
    "    print(\"\\n\" + \"=\" * 95)\n",
    "    print(title)\n",
    "    print(\"=\" * 95)\n",
    "\n",
    "def pct(x):\n",
    "    return 100 * x\n"
