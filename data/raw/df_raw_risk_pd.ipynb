    "## Optional extension: Customer segmentation (unsupervised)\n",
    "\n",
    "This section clusters customers based on behaviour features and then checks how default rates differ by cluster (post‑hoc validation)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cfe499ff",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "# =============================================================================\n",
    "# CUSTOMER SEGMENTATION — KMEANS (OPTIONAL)\n",
    "# =============================================================================\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.metrics import silhouette_score\n",
    "\n",
    "section(\"Customer segmentation (KMeans) — optional\")\n",
    "\n",
    "# pick behaviour-heavy features (drop target and ID)\n",
    "seg_cols = [c for c in df_fe.columns if c not in [\"DEFAULT_NEXT_MONTH\", \"ID\"]]\n",
    "seg_X = df_fe[seg_cols].copy()\n",
    "\n",
    "# simple preprocessing: one-hot for categorical\n",
    "seg_cat = [c for c in [\"SEX\",\"EDUCATION\",\"MARRIAGE\"] if c in seg_X.columns]\n",
    "seg_num = [c for c in seg_X.columns if c not in seg_cat]\n",
    "\n",
    "seg_X_cat = pd.get_dummies(seg_X[seg_cat].astype(int), columns=seg_cat, drop_first=False)\n",
    "seg_X_num = seg_X[seg_num].astype(float)\n",
    "\n",
    "seg_X_all = pd.concat([seg_X_num, seg_X_cat], axis=1)\n",
    "\n",
    "# scale\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(seg_X_all)\n",
    "\n",
    "# choose k by quick silhouette scan\n",
    "ks = range(2, 8)\n",
    "sil = []\n",
    "for k in ks:\n",
    "    km = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    labels = km.fit_predict(X_scaled)\n",
    "    sil.append(silhouette_score(X_scaled, labels))\n",
    "\n",
    "sil_df = pd.DataFrame({\"k\": list(ks), \"silhouette\": sil})\n",
    "print_df(sil_df, \"Silhouette by k\", n=10)\n",
    "\n",
    "best_k = int(sil_df.sort_values(\"silhouette\", ascending=False).iloc[0][\"k\"])\n",
    "print(f\"Best k by silhouette (quick scan): {best_k}\")\n",
    "\n",
    "km = KMeans(n_clusters=best_k, random_state=42, n_init=10)\n",
    "clusters = km.fit_predict(X_scaled)\n",
    "\n",
    "df_seg = df_fe[[\"DEFAULT_NEXT_MONTH\"]].copy()\n",
    "df_seg[\"cluster\"] = clusters\n",
    "\n",
    "cluster_stats = (df_seg.groupby(\"cluster\")[\"DEFAULT_NEXT_MONTH\"]\n",
    "                 .agg(count=\"size\", default_rate=\"mean\")\n",
    "                 .reset_index()\n",
    "                 .sort_values(\"default_rate\", ascending=False))\n",
    "cluster_stats[\"default_rate_pct\"] = (cluster_stats[\"default_rate\"]*100).round(2)\n",
    "\n",
    "print_df(cluster_stats, \"Default rate by cluster\", n=best_k)\n",
    "\n",
    "fig = px.bar(cluster_stats, x=\"cluster\", y=\"default_rate_pct\",\n",
    "             title=\"Default rate by KMeans cluster (post-hoc validation)\")\n",
    "fig.show()\n"
   ]
